# =========================================================================
# SHRI RAM DAIRY - ROOT-LEVEL ENVIRONMENT VARIABLES REFERENCE
# =========================================================================
# This file serves as a reference for all required configuration options for
# both the client (Vite/React) and server (Node/Express).
#
# Do NOT copy this file directly to the root as .env unless you run a custom setup.
# The application reads environment variables from:
#   1. client/.env (for frontend)
#   2. server/.env (for backend)
# =========================================================================

# -------------------------------------------------------------------------
# BACKEND CONFIGURATION (server/.env)
# -------------------------------------------------------------------------

# Environment mode: 'development' or 'production'
NODE_ENV=development

# Port on which the Express backend will run
PORT=8000

# MongoDB Connection URI (Local database or MongoDB Atlas cloud URI)
# Default local path: mongodb://127.0.0.1:27017/shree_ram_dairy
MONGODB_URI=mongodb://127.0.0.1:27017/shree_ram_dairy

# CORS allowed origin. Should match the URL where the React client runs.
# Default local path: http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# Frontend Application URL. Used in reset password links and redirections.
# Default local path: http://localhost:5173
FRONTEND_URL=http://localhost:5173

# JWT Authentication Config
# Use a random, long, secure string for secrets.
ACCESS_TOKEN_SECRET=your_access_token_secret_here_make_it_long_and_complex
ACCESS_TOKEN_EXPIRY=1d
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here_make_it_long_and_complex
REFRESH_TOKEN_EXPIRY=10d

# Cloudinary Integration (For uploading product/category photos)
# Create a free account at https://cloudinary.com to get these credentials.
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Razorpay Payments Configuration
# Create a Razorpay account and get API credentials from the settings dashboard.
# Use test keys ('rzp_test_...') for development.
RAZORPAY_KEY_ID=rzp_test_your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Google OAuth Integration (Backend reference, optional verification)
# Create client IDs on the Google Cloud Console (https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# SMTP Configuration (For password reset and order verification emails)
# For development, you can use a mock inbox service like Mailtrap (https://mailtrap.io).
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_auth_username
SMTP_PASS=your_smtp_auth_password
EMAIL_FROM=noreply@shreeramdairy.com


# -------------------------------------------------------------------------
# FRONTEND CONFIGURATION (client/.env)
# -------------------------------------------------------------------------

# API endpoint URL for the backend server.
# In local development: http://localhost:8000
# In production: The deployed backend URL (e.g., https://your-backend.onrender.com)
VITE_API_URL=http://localhost:8000

# Razorpay public key ID.
# MUST match the server's RAZORPAY_KEY_ID exactly.
VITE_RAZORPAY_KEY_ID=rzp_test_your_razorpay_key_id

# Google OAuth Client ID for the Google Login Button.
# MUST match the client ID generated in Google Cloud Console.
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
