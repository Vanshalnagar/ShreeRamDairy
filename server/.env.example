# =========================================================================
# SHRI RAM DAIRY - BACKEND SERVER ENVIRONMENT VARIABLES
# =========================================================================
# Copy this file to '.env' in the same folder and configure the variables.
# =========================================================================

# Node Environment: 'development' or 'production'
NODE_ENV=development

# Port on which the backend Express server will run
PORT=8000

# MongoDB Connection String
# For local development: mongodb://127.0.0.1:27017/shree_ram_dairy
# For production: mongodb+srv://<username>:<password>@cluster0.xxx.mongodb.net/shree_ram_dairy
MONGODB_URI=mongodb://127.0.0.1:27017/shree_ram_dairy

# CORS Allowed Origin
# MUST match the client's URL (e.g., http://localhost:5173 for local Vite dev)
CORS_ORIGIN=http://localhost:5173

# Frontend URL
# Used to construct password reset links and emails sent to users
FRONTEND_URL=http://localhost:5173

# JWT Secret Keys
# Generate long, random cryptographic strings for safety
# E.g. using `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
ACCESS_TOKEN_SECRET=your_access_token_secret_string
ACCESS_TOKEN_EXPIRY=1d
REFRESH_TOKEN_SECRET=your_refresh_token_secret_string
REFRESH_TOKEN_EXPIRY=10d

# Cloudinary Config
# Obtain these credentials from your Cloudinary console: https://cloudinary.com/
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Razorpay Config (For handling payments)
# Obtain these credentials from your Razorpay Dashboard (API Keys section)
# Use test keys ('rzp_test_...') for development/testing environments
RAZORPAY_KEY_ID=rzp_test_your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Google Client ID
# Obtain this from the Google Cloud Console for OAuth login verification
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# SMTP Server Configurations (For sending password reset links and invoice emails)
# Set up a development SMTP sandbox on Mailtrap (https://mailtrap.io) or use an active SMTP service
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_auth_user
SMTP_PASS=your_smtp_auth_pass
EMAIL_FROM=noreply@shreeramdairy.com
