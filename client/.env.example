# =========================================================================
# SHRI RAM DAIRY - FRONTEND CLIENT ENVIRONMENT VARIABLES
# =========================================================================
# Copy this file to '.env' in the same folder and configure the variables.
# =========================================================================

# Backend API Base URL
# - For local development: http://localhost:8000
# - For production: The live URL where your backend is deployed (e.g., https://your-backend.onrender.com)
# Vite requires env variables to be prefixed with 'VITE_' to be accessible on the client side.
VITE_API_URL=http://localhost:8000

# Razorpay Payments Public Key ID
# Create a Razorpay account, navigate to Settings -> API Keys, and generate keys.
# Use test keys ('rzp_test_...') for sandbox testing.
# This MUST match the server's RAZORPAY_KEY_ID variable exactly.
VITE_RAZORPAY_KEY_ID=rzp_test_your_razorpay_key_id

# Google OAuth Client ID
# Created on Google Cloud Console (APIs & Services -> Credentials -> Create OAuth client ID)
# Used to render the Google Sign-In button on the login/register pages.
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
